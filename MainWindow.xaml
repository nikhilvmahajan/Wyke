<Window x:Class="Wyke.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wyke"
        Width="420" Height="180"
        MinWidth="280" MinHeight="100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Topmost="True">
    <Grid Margin="10">
        <!-- Shadow layer -->
        <Border CornerRadius="8" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.22"
                                  Color="#000000" Direction="270"/>
            </Border.Effect>
        </Border>
        <!-- Content layer (clips TextBox to rounded corners) -->
        <Border CornerRadius="8" Background="White" ClipToBounds="True"
                MouseLeftButtonDown="Border_MouseLeftButtonDown">
            <TextBox x:Name="NoteTextBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Background="Transparent"
                     FontFamily="Segoe UI"
                     FontSize="13"
                     Foreground="#1A1A1A"
                     Padding="14"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     CaretBrush="#1A7F64"
                     SelectionBrush="#1A7F64"
                     TextChanged="NoteTextBox_TextChanged"/>
        </Border>
    </Grid>
</Window>
